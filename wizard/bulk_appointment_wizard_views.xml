<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beauty_bulk_appointment_wizard_form" model="ir.ui.view">
        <field name="name">beauty.bulk.appointment.wizard.form</field>
        <field name="model">beauty.bulk.appointment.wizard</field>
        <field name="arch" type="xml">
            <form string="Xếp lịch điều trị hàng loạt">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>Hướng dẫn:</strong> Hệ thống đã tự động sinh ra danh sách các buổi dựa trên dịch vụ trong phác đồ. 
                        Vui lòng điền <b>Thời gian</b>, <b>Phòng</b> và <b>Nhân sự</b> cho từng buổi, sau đó bấm <b>"Tạo tất cả lịch hẹn"</b>.
                    </div>
                    <group>
                        <group>
                            <field name="plan_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách xếp lịch các buổi">
                            <field name="line_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="name" readonly="1" force_save="1"/>
                                    <field name="product_id" readonly="1" force_save="1"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="room_id" options="{'no_create': True}"/>
                                    <field name="ktv_id" options="{'no_create': True}"/>
                                    <field name="doctor_id" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create_appointments" string="Tạo tất cả lịch hẹn" type="object" class="oe_highlight"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
