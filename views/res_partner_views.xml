<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_treatment_plan" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.treatment.plan</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_treatment_plans" icon="fa-medkit">
                    <field name="treatment_plan_count" widget="statinfo" string="Phác đồ"/>
                </button>
                <button class="oe_stat_button" type="object" name="action_view_appointments" icon="fa-calendar">
                    <field name="appointment_count" widget="statinfo" string="Lịch hẹn"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
