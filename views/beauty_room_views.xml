<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beauty_room_list" model="ir.ui.view">
        <field name="name">beauty.room.list</field>
        <field name="model">beauty.room</field>
        <field name="arch" type="xml">
            <list string="Danh sách Phòng điều trị" decoration-success="status=='available'" decoration-warning="status=='in_use'" decoration-danger="status=='maintenance'">
                <field name="code"/>
                <field name="name"/>
                <field name="capacity"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_beauty_room_form" model="ir.ui.view">
        <field name="name">beauty.room.form</field>
        <field name="model">beauty.room</field>
        <field name="arch" type="xml">
            <form string="Thông tin Phòng điều trị">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Đã lưu trữ" bg_color="bg-danger" invisible="active == True"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Tên phòng"/>
                        <h1>
                            <field name="name" placeholder="VD: Phòng VIP 1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="VD: P01"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="notes" placeholder="Nhập ghi chú nội bộ (nếu có)..."/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_beauty_room" model="ir.actions.act_window">
        <field name="name">Phòng điều trị</field>
        <field name="res_model">beauty.room</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phòng điều trị đầu tiên của bạn
            </p>
            <p>
                Quản lý danh sách các phòng điều trị và số lượng giường để phục vụ cho việc xếp lịch hẹn không bị trùng lặp.
            </p>
        </field>
    </record>
</odoo>