<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_remind_upcoming_appointments" model="ir.cron">
            <field name="name">HT Beauty: Nhắc lịch hẹn ngày mai</field>
            <field name="model_id" ref="ht_beauty_appointment.model_beauty_appointment"/>
            <field name="state">code</field>
            <field name="code">model._cron_remind_upcoming_appointments()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_alert_late_appointments" model="ir.cron">
            <field name="name">HT Beauty: Cảnh báo trễ hẹn</field>
            <field name="model_id" ref="ht_beauty_appointment.model_beauty_appointment"/>
            <field name="state">code</field>
            <field name="code">model._cron_alert_late_appointments()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>