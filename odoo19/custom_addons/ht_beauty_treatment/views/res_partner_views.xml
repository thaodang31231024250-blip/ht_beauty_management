<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_treatment" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.treatment</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            
            <div name="button_box" position="inside">
                <button name="action_view_treatment_plans" type="object" class="oe_stat_button" icon="fa-stethoscope">
                    <field name="treatment_plan_count" widget="statinfo" string="Phác đồ"/>
                </button>
            </div>

            <xpath expr="//page[@string='Tiến độ Điều trị']" position="inside">
                <field name="treatment_plan_ids" readonly="1">
                    <list>
                        <field name="name"/>
                        <field name="doctor_id"/>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        <field name="state" widget="badge"/>
                    </list>
                </field>
            </xpath>
            
        </field>
    </record>
</odoo>