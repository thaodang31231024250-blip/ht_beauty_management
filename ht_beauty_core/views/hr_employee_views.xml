<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_beauty" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.beauty</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="role_type"/>
                <field name="specialization" invisible="role_type not in ('doctor', 'ktv')" placeholder="VD: Da liễu, Phun xăm..."/>
            </xpath>
        </field>
    </record>
</odoo>